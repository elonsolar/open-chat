// AI平台适配器 - 统一接口
class AIPlatformAdapter {
  constructor(platform) {
    this.platform = platform;
    this.selectors = this.getSelectors(platform);
  }

  getSelectors(platform) {
    const selectorMap = {
      deepseek: {
        // DeepSeek 页面选择器 - 更通用版本
        inputBox: 'textarea, div[contenteditable="true"], #prompt-textarea',
        sendButton: 'button, button[class*="btn"], button[class*="send"], button[class*="submit"], svg, [role="button"]',
        messageList: '[class*="message"], [class*="chat"], [class*="conversation"]',
        userInput: '[class*="user"], [class*="human"], [data-message-author-role="user"]',
        aiResponse: '[class*="assistant"], [class*="ai"], [class*="bot"], [data-message-author-role="assistant"]',
        newChatButton: 'button[aria-label*="新会话"], a:contains("新会话"), button:contains("新对话")'
      },
      doubao: {
        // 豆包页面选择器 - 完全重写
        inputBox: 'textarea, div[contenteditable="true"]',
        sendButton: 'button, svg, [role="button"]',
        messageList: 'body, [class*="message"], [class*="chat"], [class*="conversation"]', // 扩大到body级别
        userInput: '*',
        aiResponse: '*',  // 先用通配符，然后过滤
        newChatButton: 'button:contains("新建对话")'
      },
      qianwen: {
        // 千问页面选择器 - 更通用版本
        inputBox: 'textarea, div[contenteditable="true"]',
        sendButton: 'button, button[class*="btn"], button[class*="send"], button[aria-label*="发送"], svg, [role="button"]',
        messageList: '[class*="message"], [class*="conversation"]',
        userInput: '[class*="user"]',
        aiResponse: '[class*="assistant"], [class*="model"]',
        newChatButton: 'button:contains("开始新对话")'
      },
      openai: {
        // ChatGPT 页面选择器
        inputBox: '#prompt-textarea, textarea',
        sendButton: 'button[data-testid="send-button"]',
        messageList: '[class*="conversation-turn"]',
        userInput: '[data-message-author-role="user"]',
        aiResponse: '[data-message-author-role="assistant"]',
        newChatButton: 'a:contains("New chat")'
      }
    };
    return selectorMap[platform] || selectorMap.deepseek;
  }

  // 等待元素出现
  waitForElement(selector, timeout = 10000) {
    return new Promise((resolve, reject) => {
      // 尝试查找元素（支持多个选择器，用逗号分隔）
      const element = document.querySelector(selector);
      if (element) {
        console.log(`[${this.platform}] 找到元素:`, selector, element);
        resolve(element);
        return;
      }

      console.warn(`[${this.platform}] 元素未找到，等待中:`, selector);

      const observer = new MutationObserver(() => {
        const element = document.querySelector(selector);
        if (element) {
          observer.disconnect();
          console.log(`[${this.platform}] 元素已出现:`, selector);
          resolve(element);
        }
      });

      observer.observe(document.body, {
        childList: true,
        subtree: true
      });

      setTimeout(() => {
        observer.disconnect();
        console.error(`[${this.platform}] 元素查找超时:`, selector);
        reject(new Error(`元素未找到: ${selector}。请确保页面已完全加载，且当前支持该平台。`));
      }, timeout);
    });
  }

  // 等待AI回复 - 使用MutationObserver版本（更可靠）
  async waitForResponse(timeout = 60000) {
    const startTime = Date.now();
    let foundNewContent = false;
    let lastContent = '';

    console.log(`[${this.platform}] ========== 开始等待AI回复（MutationObserver模式） ==========`);
    console.log(`[${this.platform}] 超时设置: ${timeout}ms`);

    return new Promise((resolve, reject) => {
      // 先检查是否已经有回复了
      const initialCheck = this.checkExistingResponse();
      if (initialCheck) {
        console.log(`[${this.platform}] 已有现成的回复，直接返回`);
        resolve(initialCheck);
        return;
      }

      console.log(`[${this.platform}] 未找到现成回复，开始监听DOM变化...`);

      const observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (mutation.type === 'childList' || mutation.type === 'characterData' || mutation.type === 'subtree') {
            const checkResult = this.checkForNewContent();
            if (checkResult.found) {
              console.log(`[${this.platform}] ✓ 检测到新内容!`);
              console.log(`[${this.platform}] 内容预览:`, checkResult.content.substring(0, 100));

              // 等待一小段时间确保内容完整
              setTimeout(() => {
                observer.disconnect();
                resolve(checkResult.content);
              }, 2000);
              return;
            }
          }
        }
      });

      // 开始监听整个body或document
      const targetNode = document.body || document;
      observer.observe(targetNode, {
        childList: true,
        subtree: true,
        characterData: true
      });

      // 超时检查
      setTimeout(() => {
        observer.disconnect();

        // 最后一次检查
        const finalCheck = this.checkForNewContent();
        if (finalCheck.found && finalCheck.content.length > 10) {
          console.log(`[${this.platform}] ========== 超时前发现回复 ==========`);
          resolve(finalCheck.content);
        } else {
          console.error(`[${this.platform}] ========== 等待超时 ==========`);
          console.error(`[${this.platform}] 尝试了 ${timeout / 1000} 秒`);
          console.error(`[${this.platform}] 建议: 检查页面是否有新的对话气泡出现`);
          console.error(`[${this.platform}] 如果AI已经回复，请手动复制回复内容`);
          reject(new Error(`等待AI回复超时 (${timeout / 1000}秒)。但AI可能已经回复了，请在豆包页面查看。`));
        }
      }, timeout);
    });
  }

  // 检查是否已有回复
  checkExistingResponse() {
    console.log(`[${this.platform}] 检查是否已有回复...`);

    try {
      // 查找所有可能包含文本的元素
      const allElements = document.querySelectorAll('div, p, span, article, section');
      console.log(`[${this.platform}] 页面共有 ${allElements.length} 个元素`);

      // 倒序查找，优先找最新的
      for (let i = allElements.length - 1; i >= Math.max(0, allElements.length - 50); i--) {
        const el = allElements[i];
        const text = el.textContent?.trim();

        // 查找包含关键词的元素（豆包可能用这些词）
        if (text && text.length > 10 && text.length < 5000) {
          // 简单的启发式：文本较长，可能是回复
          // 排除导航和菜单项
          const isNav = el.closest('nav, header, footer, .nav, .header, .footer');
          const isButton = el.closest('button, [role="button"]');

          if (!isNav && !isButton && !el.closest('.toolbar')) {
            console.log(`[${this.platform}] 可能的回复元素:`, el.tagName, el.className);
            console.log(`[${this.platform}] 内容预览:`, text.substring(0, 50) + '...');
            return text;
          }
        }
      }
    } catch (e) {
      console.warn(`[${this.platform}] 检查现有回复时出错:`, e);
    }

    return null;
  }

  // 检查是否有新内容
  checkForNewContent() {
    try {
      // 使用多种策略查找回复
      const strategies = [
        // 策略1: 使用选择器（如果有）
        this.selectors.aiResponse && this.selectors.aiResponse !== '*'
          ? Array.from(document.querySelectorAll(this.selectors.aiResponse))
          : [],

        // 策略2: 查找所有可能包含AI回复的元素
        Array.from(document.querySelectorAll('div, p, section, article')).filter(el => {
          const text = el.textContent?.trim();
          // 简单的启发式规则
          return text && text.length > 20 && text.length < 10000;
        })
      ];

      for (const elements of strategies) {
        if (elements.length > 0) {
          const lastElement = elements[elements.length - 1];
          const content = lastElement.textContent?.trim();

          if (content && content.length > 10) {
            console.log(`[${this.platform}] 找到回复元素:`, lastElement.tagName);
            return { found: true, content: content };
          }
        }
      }

      return { found: false, content: '' };
    } catch (e) {
      console.warn(`[${this.platform}] 检查新内容时出错:`, e);
      return { found: false, content: '' };
    }
  }

  // 等待AI回复 - 使用MutationObserver版本（更可靠）
  async waitForResponse(timeout = 60000) {
    const startTime = Date.now();
    let lastContentLength = 0;
    let lastContent = '';

    console.log(`[${this.platform}] ========== 开始等待AI回复 ==========`);
    console.log(`[${this.platform}] 超时设置: ${timeout}ms`);

    return new Promise((resolve, reject) => {
      // 使用MutationObserver监听DOM变化
      const observer = new MutationObserver((mutations) => {
        const elapsed = Date.now() - startTime;

        // 检查是否有新内容
        const result = this.checkForNewContent();
        if (result.found && result.content.length > lastContentLength) {
          console.log(`[${this.platform}] 检测到新内容，长度: ${result.content.length}`);
          lastContent = result.content;
          lastContentLength = result.content.length;

          // 等待内容稳定（3秒内长度不再增长）
          setTimeout(() => {
            if (lastContent.length > 20) {
              console.log(`[${this.platform}] ========== AI回复完成 ==========`);
              console.log(`[${this.platform}] 回复长度: ${lastContent.length} 字符`);
              console.log(`[${this.platform}] 回复预览:`, lastContent.substring(0, 100) + '...');
              console.log(`[${this.platform}] 总耗时: ${Math.floor(elapsed / 1000)}秒`);
              observer.disconnect();
              resolve(lastContent);
            }
          }, 3000);
        }
      });

      // 开始观察DOM变化
      try {
        observer.observe(document.body, {
          childList: true,
          subtree: true,
          characterData: true
        });
      } catch (e) {
        console.warn(`[${this.platform}] MutationObserver启动失败:`, e);
      }

      // 超时处理
      setTimeout(() => {
        observer.disconnect();
        if (lastContent && lastContent.length > 0) {
          console.log(`[${this.platform}] ========== 超时但已有内容 ==========`);
          resolve(lastContent);
        } else {
          console.error(`[${this.platform}] ========== 等待超时 ==========`);
          console.error(`[${this.platform}] 总等待时间: ${Math.floor((Date.now() - startTime) / 1000)}秒`);
          reject(new Error(`等待AI回复超时 (${timeout/1000}秒)`));
        }
      }, timeout);
    });
  }

  // 发送消息 - 增强版
  async sendMessage(content) {
    try {
      console.log(`[${this.platform}] ========== 发送消息 ==========`);
      console.log(`[${this.platform}] 消息内容:`, content);
      console.log(`[${this.platform}] 平台URL:`, window.location.href);
      console.log(`[${this.platform}] 页面标题:`, document.title);

      // 等待输入框
      console.log(`[${this.platform}] 步骤1: 等待输入框...`);
      const inputBox = await this.waitForElement(this.selectors.inputBox, 10000);
      console.log(`[${this.platform}] ✓ 找到输入框:`, inputBox.tagName, inputBox.className);

      // 聚焦并填入消息
      console.log(`[${this.platform}] 步骤2: 填入消息...`);
      inputBox.focus();
      inputBox.value = content;
      inputBox.dispatchEvent(new Event('input', { bubbles: true }));
      await this.sleep(1000);

      // 按Enter发送
      console.log(`[${this.platform}] 步骤3: 按Enter发送...`);
      inputBox.dispatchEvent(new KeyboardEvent('keydown', {
        key: 'Enter', code: 'Enter', keyCode: 13, bubbles: true
      }));
      await this.sleep(2000);

      // 等待AI回复
      console.log(`[${this.platform}] 步骤4: 等待AI回复...`);
      const response = await this.waitForResponse();
      console.log(`[${this.platform}] ========== 收到回复 ==========`);
      console.log(`[${this.platform}] 回复长度:`, response.length);

      return response;
    } catch (error) {
      console.error(`[${this.platform}] ========== 发送消息失败 ==========`);
      console.error(`[${this.platform}] 错误:`, error.message);
      throw error;
    }
  }

  // 创建新会话
  async newChat() {
    try {
      console.log(`[${this.platform}] 创建新会话`);

      // 尝试点击新会话按钮
      const newChatButton = document.querySelector(this.selectors.newChatButton);
      if (newChatButton) {
        newChatButton.click();
        await this.sleep(1000);
        return true;
      }

      return false;
    } catch (error) {
      console.error(`[${this.platform}] 创建新会话失败:`, error);
      return false;
    }
  }
}

// 辅助方法：延迟
sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}
}

// 导出到全局
window.AIPlatformAdapter = AIPlatformAdapter;
              console.log(`[${this.platform}] Body级别找到: ${bodyMessages.length} 个可能的用户消息`);

              if (bodyMessages.length > 0) {
                console.log(`[${this.platform}] 在body级别找到用户消息！`);
                userMessages = bodyMessages;
              }
            }
          }

          // 获取最后一条用户消息后的所有元素
          const lastUserMsg = userMessages[userMessages.length - 1];
          const allSiblings = Array.from(lastUserMsg.parentElement.children);
          const lastUserIndex = allSiblings.indexOf(lastUserMsg);
          const afterLastUser = allSiblings.slice(lastUserIndex + 1);

          console.log(`[${this.platform}] 用户消息后有 ${afterLastUser.length} 个元素`);

          // 检查这些元素，看是否有AI回复
          let aiContent = '';
          let hasNewContent = false;

          for (const elem of afterLastUser) {
            const text = elem.textContent || '';
            if (text.trim().length > 0) {
              // 检查是否是AI回复
              const isAiResponse = elem.matches(this.selectors.aiResponse) ||
                                 elem.closest(this.selectors.aiResponse);

              if (isAiResponse) {
                console.log(`[${this.platform}] 发现可能的AI回复元素:`, elem.tagName, elem.className);
                aiContent = text.trim();
                hasNewContent = true;
                break;
              }
            }
          }

          console.log(`[${this.platform}] AI内容长度: ${aiContent.length}, 新内容: ${hasNewContent}`);

          // 如果找到AI回复且有内容
          if (hasNewContent && aiContent.length > 0) {
            // 检查内容是否稳定（不是临时加载文本）
            if (aiContent.length > lastContentLength) {
              console.log(`[${this.platform}] 内容增长: ${lastContentLength} → ${aiContent.length}`);

              // 等待一小段时间确保内容完整
              if (aiContent.length > 20 && elapsed > 3000) {
                console.log(`[${this.platform}] ========== AI回复完成 ==========`);
                console.log(`[${this.platform}] 回复长度: ${aiContent.length} 字符`);
                console.log(`[${this.platform}] 回复预览:`, aiContent.substring(0, 100) + '...');
                console.log(`[${this.platform}] 总耗时: ${Math.floor(elapsed / 1000)}秒`);
                clearInterval(checkInterval);
                resolve(aiContent);
                return;
              }

              lastContentLength = aiContent.length;
            }
          }

          // 超时检查
          if (elapsed > timeout) {
            console.error(`[${this.platform}] ========== 等待超时 ==========`);
            console.error(`[${this.platform}] 总等待时间: ${Math.floor(elapsed / 1000)}秒`);
            console.error(`[${this.platform}] 用户消息数: ${userMessages.length}`);
            console.error(`[${this.platform}] 最后内容长度: ${lastContentLength}`);
            console.error(`[${this.platform}] 可能原因:`);
            console.error(`  1. AI响应时间过长`);
            console.error(`  2. 页面结构变化，选择器不匹配`);
            console.error(`  3. 网络问题`);
            console.error(`[${this.platform}] 建议: 刷新页面后重试`);
            clearInterval(checkInterval);
            reject(new Error(`等待AI回复超时 (${Math.floor(elapsed / 1000)}秒)。可能原因：页面结构变化、网络慢或AI响应时间过长。`));
          }
        } catch (error) {
          console.error(`[${this.platform}] 检查过程出错:`, error);
        }
      }, 500);
    });
  }

  // 发送消息 - 增强版
  async sendMessage(content) {
    try {
      console.log(`[${this.platform}] ========== 发送消息 ==========`);
      console.log(`[${this.platform}] 消息内容:`, content);
      console.log(`[${this.platform}] 平台URL:`, window.location.href);
      console.log(`[${this.platform}] 页面标题:`, document.title);

      // 等待输入框
      console.log(`[${this.platform}] 步骤1: 等待输入框...`);
      const inputBox = await this.waitForElement(this.selectors.inputBox, 10000);
      console.log(`[${this.platform}] ✓ 找到输入框:`, inputBox.tagName, inputBox.className);
      console.log(`[${this.platform}] 输入框placeholder:`, inputBox.placeholder);
      console.log(`[${this.platform}] 输入框初始值:`, inputBox.value);

      // 聚焦并输入 - 使用多种方法确保输入成功
      console.log(`[${this.platform}] 步骤2: 聚焦并填入消息...`);
      inputBox.focus();

      // 方法1: 设置value属性
      inputBox.value = content;

      // 方法2: 使用原生InputEvent（更可靠）
      const inputEvent = new InputEvent('input', {
        bubbles: true,
        cancelable: true,
        data: content
      });
      inputBox.dispatchEvent(inputEvent);

      // 方法3: 使用CustomEvent
      const customEvent = new CustomEvent('input', { detail: content, bubbles: true });
      inputBox.dispatchEvent(customEvent);

      // 方法4: 使用document.execCommand模拟真实输入（最可靠）
      console.log(`[${this.platform}] 使用execCommand模拟真实输入...`);
      inputBox.value = ''; // 先清空
      inputBox.focus();

      try {
        document.execCommand('insertText', false, content);
        console.log(`[${this.platform}] ✓ execCommand插入成功`);
      } catch (e) {
        console.warn(`[${this.platform}] execCommand失败，使用备选方案:`, e);
        // 备选方案
        inputBox.value = content;

        // 触发多个事件确保生效
        const events = [
          new KeyboardEvent('keydown', { key: 'End', bubbles: true }),
          new KeyboardEvent('keypress', { key: 'End', bubbles: true }),
          new KeyboardEvent('keyup', { key: 'End', bubbles: true }),
          new Event('input', { bubbles: true }),
          new Event('change', { bubbles: true })
        ];

        for (const evt of events) {
          inputBox.dispatchEvent(evt);
        }

        // 再次设置值并触发事件
        inputBox.value = content;
        inputBox.dispatchEvent(new Event('input', { bubbles: true }));
      }

      // 验证输入框的值
      const finalValue = inputBox.value;
      console.log(`[${this.platform}] 最终输入框值:`, finalValue);
      console.log(`[${this.platform}] 输入框值长度:`, finalValue ? finalValue.length : 0);

      // 如果值为空，说明输入失败
      if (!finalValue || finalValue.length === 0) {
        throw new Error('输入框值仍为空，可能不支持自动输入。请检查页面是否完全加载。');
      }

      // 输入成功，等待稳定
      console.log(`[${this.platform}] ✓ 输入成功！`);
      console.log(`[${this.platform}] 步骤3: 等待输入稳定...`);
      await this.sleep(2000);
      console.log(`[${this.platform}] ✓ 输入已稳定`);

      // 尝试点击发送按钮
      console.log(`[${this.platform}] 步骤4: 尝试发送消息...`);

      // 首先尝试按Enter
      console.log(`[${this.platform}] 方法A: 尝试按Enter键`);
      const enterEvent = new KeyboardEvent('keydown', {
        key: 'Enter',
        code: 'Enter',
        keyCode: 13,
        which: 13,
        bubbles: true,
        cancelable: true,
        compose: true,
        keyCode: 13
      });
      const prevented = inputBox.dispatchEvent(enterEvent);
      console.log(`[${this.platform}] Enter事件结果:`, prevented);

      // 如果Enter没有被阻止，等待一下看看是否发送
      if (!prevented) {
        console.log(`[${this.platform}] Enter未被阻止，等待2秒...`);
        await this.sleep(2000);
      }

      // 查找并点击发送按钮
      console.log(`[${this.platform}] 方法B: 查找并发送按钮`);
      try {
        // 先尝试精确匹配
        let sendButton = await this.waitForElement(this.selectors.sendButton, 2000);
        console.log(`[${this.platform}] 找到按钮元素:`, sendButton);
        console.log(`[${this.platform}] 按钮文本:`, sendButton.textContent);
        console.log(`[${this.platform}] 按钮class:`, sendButton.className);
        console.log(`[${this.platform}] 按钮id:`, sendButton.id);
        console.log(`[${this.platform}] 按钮disabled:`, sendButton.disabled);

        // 检查按钮是否可点击
        if (!sendButton.disabled) {
          console.log(`[${this.platform}] 尝试点击按钮...`);
          sendButton.click();
          console.log(`[${this.platform}] ✓ 已点击发送按钮`);
        } else {
          console.warn(`[${this.platform}] 按钮被禁用，尝试其他方法`);
        }
      } catch (buttonError) {
        console.warn(`[${this.platform}] 未找到明确的发送按钮`);
        console.log(`[${this.platform}] 方法C: 查找所有可能的按钮`);

        // 查找所有按钮，找到最像发送按钮的
        const allButtons = document.querySelectorAll('button, [role="button"]');
        console.log(`[${this.platform}] 页面共有 ${allButtons.length} 个按钮元素`);

        let found = false;
        for (let i = 0; i < allButtons.length; i++) {
          const btn = allButtons[i];
          const text = btn.textContent?.toLowerCase() || '';
          const ariaLabel = btn.getAttribute('aria-label')?.toLowerCase() || '';
          const className = btn.className?.toLowerCase() || '';
          const hasSvg = btn.querySelector('svg');

          // 检查是否像发送按钮
          const isSendLike = text.includes('发送') || text.includes('send') ||
                           ariaLabel.includes('发送') || ariaLabel.includes('send') ||
                           className.includes('send') || className.includes('submit') ||
                           hasSvg;

          console.log(`[${this.platform}] 按钮${i}: text="${text}" aria-label="${ariaLabel}" class="${className}" hasSvg=${hasSvg} isSend=${isSendLike}`);

          if (isSendLike && !found) {
            console.log(`[${this.platform}] 找到可能的发送按钮，点击它...`);
            btn.click();
            found = true;
            break;
          }
        }

        if (!found) {
          console.warn(`[${this.platform}] 未找到明显的发送按钮，可能已经发送了`);
        }
      }

      // 等待一下让消息发送
      console.log(`[${this.platform}] 步骤5: 等待消息发送并验证...`);
      await this.sleep(3000);

      // 手动检查页面状态
      console.log(`[${this.platform}] 检查页面状态...`);
      const checkInput = document.querySelector(this.selectors.inputBox);
      console.log(`[${this.platform}] 输入框当前值:`, checkInput ? checkInput.value?.substring(0, 50) : '未找到');

      // 尝试查找任何新出现的元素
      const allElements = document.querySelectorAll('*');
      console.log(`[${this.platform}] 页面总元素数:`, allElements.length);

      // 查找包含我们发送内容的元素
      const sentElements = Array.from(allElements).filter(el => {
        return el.textContent && el.textContent.includes(content);
      });
      console.log(`[${this.platform}] 包含消息的元素数:`, sentElements.length);

      if (sentElements.length > 0) {
        console.log(`[${this.platform}] ✓ 发现包含消息的元素!`);
        sentElements.forEach((el, index) => {
          if (index < 3) {
            console.log(`  元素${index}:`, el.tagName, el.className);
          }
        });
      } else {
        console.warn(`[${this.platform}] ⚠️ 未发现包含消息的元素，可能发送失败`);
      }

      console.log(`[${this.platform}] 步骤6: 等待AI回复...`);
      await this.sleep(2000);

      // 等待AI回复
      console.log(`[${this.platform}] ========== 开始等待AI回复 ==========`);
      const response = await this.waitForResponse();
      console.log(`[${this.platform}] ========== 收到完整回复 ==========`);

      return response;
    } catch (error) {
      console.error(`[${this.platform}] ========== 发送消息失败 ==========`);
      console.error(`[${this.platform}] 错误类型:`, error.constructor.name);
      console.error(`[${this.platform}] 错误信息:`, error.message);
      console.error(`[${this.platform}] 错误堆栈:`, error.stack);

      // 输出页面状态用于调试
      try {
        console.error(`[${this.platform}] 页面状态:`);
        console.error(`  URL:`, window.location.href);
        console.error(`  标题:`, document.title);
        const input = document.querySelector('textarea');
        console.error(`  输入框存在:`, !!input);
        const buttons = document.querySelectorAll('button');
        console.error(`  按钮数量:`, buttons.length);
      } catch (e) {}

      throw error;
    }
  }

  // 创建新会话
  async newChat() {
    try {
      console.log(`[${this.platform}] 创建新会话`);

      // 尝试点击新会话按钮
      const newChatButton = document.querySelector(this.selectors.newChatButton);
      if (newChatButton) {
        newChatButton.click();
        await this.sleep(1000);
        return true;
      }

      // 如果没有新会话按钮，尝试通过URL
      const currentUrl = window.location.href;
      const newUrl = currentUrl.split('?')[0] + '?new=true';
      window.location.href = newUrl;

      await this.sleep(2000);
      return true;
    } catch (error) {
      console.error(`[${this.platform}] 创建新会话失败:`, error);
      return false;
    }
  }

  // 获取当前会话的所有消息
  async getChatHistory() {
    try {
      const messageList = document.querySelector(this.selectors.messageList);
      if (!messageList) {
        return [];
      }

      const messages = [];
      const userMessages = messageList.querySelectorAll(this.selectors.userInput);
      const aiMessages = messageList.querySelectorAll(this.selectors.aiResponse);

      userMessages.forEach((msg, index) => {
        messages.push({
          role: 'user',
          content: msg.textContent.trim(),
          timestamp: Date.now()
        });

        if (aiMessages[index]) {
          messages.push({
            role: 'assistant',
            content: aiMessages[index].textContent.trim(),
            timestamp: Date.now()
          });
        }
      });

      return messages;
    } catch (error) {
      console.error(`[${this.platform}] 获取聊天历史失败:`, error);
      return [];
    }
  }

  // 辅助方法：延迟
  sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
}

// 导出到全局
window.AIPlatformAdapter = AIPlatformAdapter;
