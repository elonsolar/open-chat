{
  "manifest_version": 3,
  "name": "多模型AI对话助手",
  "version": "1.0.0",
  "description": "集成多个大模型，支持角色管理和会话管理的AI对话助手",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "webNavigation",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*",
        "https://deepseek.com/*"
      ],
      "js": ["utils/platform-adapter.js", "utils/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": ["utils/platform-adapter.js", "utils/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.qianwen.com/*",
        "https://qianwen.com/*"
      ],
      "js": ["utils/platform-adapter.js", "utils/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["utils/platform-adapter.js", "utils/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["utils/floating-window.js", "utils/floating-content.js"],
      "run_at": "document_end",
      "exclude_matches": [
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*",
        "https://deepseek.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
